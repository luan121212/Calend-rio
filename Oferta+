<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ofertas BR</title>

<style>
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#f5f5f5;
}
header{
    background:#ff3b30;
    color:white;
    padding:20px;
    text-align:center;
}
.produtos{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    padding:20px;
}
.card{
    background:white;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,.2);
    overflow:hidden;
}
.card img{
    width:100%;
    height:200px;
    object-fit:cover;
}
.info{
    padding:15px;
}
.preco{
    color:#ff3b30;
    font-size:24px;
    font-weight:bold;
}
button{
    background:#28a745;
    color:white;
    border:none;
    padding:10px;
    width:100%;
    border-radius:5px;
    cursor:pointer;
}
button:hover{
    background:#218838;
}
</style>
</head>

<body>

<header>
<h1>🔥 Ofertas BR</h1>
<p>Os melhores descontos em um só lugar</p>
</header>

<div class="produtos" id="produtos"></div>

<script>

const ofertas=[
{
nome:"Smartphone",
preco:"R$ 999",
img:"https://picsum.photos/300/200?1"
},
{
nome:"Notebook",
preco:"R$ 2.499",
img:"https://picsum.photos/300/200?2"
},
{
nome:"Fone Bluetooth",
preco:"R$ 89",
img:"https://picsum.photos/300/200?3"
},
{
nome:"Smart TV",
preco:"R$ 1.799",
img:"https://picsum.photos/300/200?4"
}
];

const lista=document.getElementById("produtos");

ofertas.forEach(item=>{
lista.innerHTML+=`
<div class="card">
<img src="${item.img}">
<div class="info">
<h2>${item.nome}</h2>
<p class="preco">${item.preco}</p>
<button onclick="alert('Oferta selecionada!')">
Ver Oferta
</button>
</div>
</div>
`;
});

</script>

</body>
</html>
